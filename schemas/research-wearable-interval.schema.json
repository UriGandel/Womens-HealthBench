{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://womens-healthbench.example/schemas/research-wearable-interval.schema.json",
  "title": "Pseudonymous six-hour wearable aggregate",
  "description": "Public interchange schema for relative-day interval aggregates. It excludes absolute dates, timestamps, timezone, platform, device/source identifiers, and raw samples.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "participant_id",
    "day_in_study",
    "bucket_index",
    "steps",
    "activity_minutes",
    "active_energy_kcal",
    "heart_rate_avg_bpm",
    "heart_rate_min_bpm",
    "heart_rate_max_bpm",
    "heart_rate_sample_count",
    "hrv_avg_ms",
    "hrv_sample_count",
    "hrv_method",
    "respiratory_rate_avg_bpm",
    "respiratory_rate_sample_count",
    "oxygen_saturation_avg_pct",
    "oxygen_saturation_sample_count",
    "source"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "participant_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "day_in_study": { "type": "integer", "minimum": 0 },
    "bucket_index": { "type": "integer", "minimum": 0, "maximum": 3 },
    "steps": { "type": ["integer", "null"], "minimum": 0, "maximum": 250000 },
    "activity_minutes": { "type": ["integer", "null"], "minimum": 0, "maximum": 480 },
    "active_energy_kcal": { "type": ["number", "null"], "minimum": 0, "maximum": 25000 },
    "heart_rate_avg_bpm": { "type": ["number", "null"], "minimum": 20, "maximum": 300 },
    "heart_rate_min_bpm": { "type": ["number", "null"], "minimum": 20, "maximum": 300 },
    "heart_rate_max_bpm": { "type": ["number", "null"], "minimum": 20, "maximum": 300 },
    "heart_rate_sample_count": { "type": ["integer", "null"], "minimum": 1 },
    "hrv_avg_ms": { "type": ["number", "null"], "minimum": 0, "maximum": 1000 },
    "hrv_sample_count": { "type": ["integer", "null"], "minimum": 1 },
    "hrv_method": { "type": ["string", "null"], "enum": ["sdnn", "rmssd", null] },
    "respiratory_rate_avg_bpm": { "type": ["number", "null"], "minimum": 1, "maximum": 100 },
    "respiratory_rate_sample_count": { "type": ["integer", "null"], "minimum": 1 },
    "oxygen_saturation_avg_pct": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "oxygen_saturation_sample_count": { "type": ["integer", "null"], "minimum": 1 },
    "source": { "enum": ["private-alpha"] }
  }
}
